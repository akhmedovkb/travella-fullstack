# ================================
# SERVER
# ================================
PORT=5000
TZ=Asia/Tashkent
JWT_SECRET=your_super_secret_here

# ================================
# DATABASE
# ================================
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# ================================
# GEONAMES
# ================================
GEONAMES_USERNAME=your_geonames_username

# ================================
# TELEGRAM — MAIN BOT (travella.uz)
# ================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret

# ================================
# TELEGRAM — CLIENT BOT
# ================================
TELEGRAM_CLIENT_BOT_TOKEN=your_client_bot_token

# ================================
# TELEGRAM — ADMINS
# ================================
TELEGRAM_ADMIN_CHAT_IDS=123456789
TELEGRAM_MANAGER_CHAT_ID=123456789

# ================================
# SITE
# ================================
SITE_PUBLIC_URL=https://travella.uz
TG_IMAGE_BASE=https://your-backend-domain

# ================================
# PAYME (если используешь)
# ================================
PAYME_MERCHANT_LOGIN=your_login
PAYME_MERCHANT_KEY=your_key

# ================================
# DONAS DOSAS
# ================================
DONAS_PUBLIC_KEY=your_public_key
